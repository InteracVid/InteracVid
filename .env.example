# YouTube Reaction Pipeline Configuration
# Copy this file to .env and fill in your values

# ===========================================
# API Keys (REQUIRED)
# ===========================================

# Gemini API key for VLM processing
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API key (optional, for text processing)
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# LLM Provider Configuration
# ===========================================

# Choose LLM provider: 'gemini' or 'openai'
LLM_PROVIDER=gemini

# OpenAI-compatible API base URL (optional)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini API endpoint (optional)
# GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# ===========================================
# Processing Configuration
# ===========================================

# Maximum concurrent workers for parallel processing
MAX_WORKERS=30

# ===========================================
# Paths Configuration
# ===========================================

# Input directory for source files
INPUT_DIR=./data/input

# Output directory for processed files
OUTPUT_DIR=./data/output

# Prompts directory
PROMPTS_DIR=./prompts
